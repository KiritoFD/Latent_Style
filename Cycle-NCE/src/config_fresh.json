{
  "model": {
    "latent_channels": 4,
    "base_dim": 128,
    "style_dim": 256,
    "projector_dim": 256,
    "num_styles": 2,
    "num_res_blocks": 2,
    "num_groups": 4,
    "latent_scale_factor": 0.18215,
    "residual_gain": 0.1,
    "style_ref_gain": 1.5
  },
  "loss": {
    "w_code": 10.0,
    "w_cycle": 10.0,
    "w_gram": 20.0,
    "w_nce": 1.0,
    "nce_warmup_epochs": 5,
    "nce_ramp_epochs": 20,
    "cycle_warmup_epochs": 5,
    "cycle_ramp_epochs": 20,
    "nce_temperature": 0.07,
    "nce_spatial_size": 16,
    "nce_max_tokens": 1024
  },
  "training": {
    "seed": 42,
    "batch_size": 8,
    "accumulation_steps": 1,
    "num_workers": 8,
    "persistent_workers": false,
    "prefetch_factor": 2,
    "pin_memory": false,
    "learning_rate": 0.0002,
    "min_learning_rate": 1e-05,
    "weight_decay": 0.0,
    "scheduler": "cosine",
    "grad_clip_norm": 1.0,
    "num_epochs": 200,
    "save_interval": 100,
    "full_eval_interval": 100,
    "full_eval_on_last_epoch": true,
    "full_eval_batch_size": 4,
    "full_eval_max_src_samples": 100,
    "full_eval_max_ref_compare": 32,
    "full_eval_max_ref_cache": 200,
    "full_eval_ref_feature_batch_size": 32,
    "test_image_dir": "../../style_data/train",
    "full_eval_cache_dir": "../../eval_cache",
    "full_eval_classifier_only": false,
    "full_eval_disable_lpips": true,
    "log_interval": 5,
    "use_tqdm": true,
    "use_amp": true,
    "amp_dtype": "bf16",
    "allow_tf32": true,
    "channels_last": true,
    "use_gradient_checkpointing": false,
    "use_compile": false,
    "fused_adamw": true,
    "skip_oom_batches": true,
    "empty_cache_interval": 0,
    "log_vram_interval": 0,
    "resume_checkpoint": ""
  },
  "data": {
    "data_root": "../../latents_train",
    "style_subdirs": ["photo", "Hayao"],
    "content_style": "photo",
    "allow_hflip": false,
    "preload_to_gpu": false,
    "virtual_length_multiplier": 8
  },
  "checkpoint": {
    "save_dir": "../adacut_overfit"
  },
  "inference": {
    "num_steps": 1,
    "temperature_lambda": 0.0,
    "temperature_threshold": 1.0,
    "use_cfg": false,
    "cfg_scale": 1.0,
    "use_source_repulsion": false,
    "repulsion_strength": 0.0
  }
}
