{
  "model": {
    "latent_channels": 4,
    "num_styles": 2,
    "base_dim": 128,
    "lift_channels": 128,
    "style_dim": 256,
    "projector_dim": 256,
    "num_hires_blocks": 6,
    "num_res_blocks": 2,
    "residual_gain": 0.2,
    "use_style_texture_head": true,
    "style_texture_gain": 0.18,
    "use_delta_highpass_bias": true,
    "style_delta_lowfreq_gain": 0.22,
    "use_content_skip_fusion": true,
    "content_skip_gain": 0.6,
    "use_style_skip_gate": true
  },
  "loss": {
    "disable_cls_ce": true,
    "w_cls": 0.0,
    "w_prob": 1.0,
    "w_prob_margin": 1.4,
    "w_dir": 0.5,
    "w_distill": 0.8,
    "w_code": 1.0,
    "w_proto": 0.2,
    "w_proto_sep": 1.2,
    "w_ref_sep": 2.5,
    "ref_sep_margin": 0.55,
    "w_spatial_proto": 2.0,
    "w_cycle": 8.0,
    "w_idt": 0.15,
    "w_gram_hf": 2.2,
    "w_moment_hf": 1.1,
    "w_featmatch_hf": 3.0,
    "style_feat_use_highpass": true,
    "prob_gate_enabled": true,
    "prob_gate_min": 0.2,
    "prob_gate_power": 1.2,
    "style_classifier_ckpt": "./style_classifier.pt",
    "style_classifier_input_size_train": 8,
    "style_classifier_input_size_infer": 8,
    "style_classifier_lowpass_size": 8
  },
  "training": {
    "seed": 42,
    "batch_size": 50,
    "num_epochs": 20,
    "num_workers": 8,
    "prefetch_factor": 2,
    "persistent_workers": false,
    "auto_preload_latents_to_gpu": true,
    "auto_preload_gpu_budget_mb": 512,
    "learning_rate": 0.0002,
    "min_learning_rate": 1e-05,
    "scheduler": "cosine",
    "grad_clip_norm": 1.0,
    "save_interval": 10,
    "full_eval_interval": 20,
    "full_eval_on_last_epoch": true,
    "full_eval_batch_size": 8,
    "full_eval_max_src_samples": 50,
    "full_eval_disable_xformers": true,
    "use_amp": true,
    "amp_dtype": "bf16",
    "allow_tf32": true,
    "channels_last": true,
    "cuda_prefetch": true,
    "fused_adamw": true,
    "use_compile": false,
    "skip_oom_batches": true,
    "log_interval": 5
  },
  "data": {
    "data_root": "../../latents_overfit50",
    "style_subdirs": ["photo", "Hayao"],
    "content_style": "any",
    "allow_hflip": false,
    "preload_to_gpu": true,
    "virtual_length_multiplier": 20
  },
  "checkpoint": {
    "save_dir": "../overfit50_clean"
  }
}
