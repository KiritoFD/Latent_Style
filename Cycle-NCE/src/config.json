{
  "model": {
    "latent_channels": 4,
    "base_dim": 128,
    "style_dim": 256,
    "projector_dim": 256,
    "num_styles": 2,
    "num_res_blocks": 2,
    "num_groups": 4,
    "latent_scale_factor": 0.18215,
    "residual_gain": 0.1
  },
  "loss": {
    "w_gram": 30.0,
    "w_moment": 30.0,
    "w_code": 10.0,
    "w_nce": 0.0,
    "w_idt": 10.0,
    "w_cycle": 50.0,
    "nce_temperature": 0.07,
    "nce_spatial_size": 16,
    "nce_max_tokens": 1024
  },
  "training": {
    "seed": 42,
    "batch_size": 128,
    "accumulation_steps": 1,
    "num_workers": 4,
    "persistent_workers": true,
    "prefetch_factor": 2,
    "pin_memory": true,
    "learning_rate": 0.0001,
    "min_learning_rate": 1e-05,
    "weight_decay": 1e-05,
    "scheduler": "cosine",
    "grad_clip_norm": 1.0,
    "num_epochs": 500,
    "save_interval": 10,
    "full_eval_interval": 50,
    "full_eval_on_last_epoch": true,
    "full_eval_batch_size": 8,
    "full_eval_max_src_samples": 30,
    "full_eval_max_ref_compare": 50,
    "test_image_dir": "../../style_data/test",
    "full_eval_cache_dir": "../../eval_cache",
    "log_interval": 50,
    "use_tqdm": true,
    "use_amp": true,
    "amp_dtype": "bf16",
    "allow_tf32": true,
    "channels_last": true,
    "use_gradient_checkpointing": true,
    "use_compile": true,
    "compile_mode": "reduce-overhead",
    "fused_adamw": true,
    "skip_oom_batches": true,
    "empty_cache_interval": 0,
    "log_vram_interval": 0,
    "resume_checkpoint": ""
  },
  "data": {
    "data_root": "../../latents",
    "style_subdirs": ["photo", "Hayao"],
    "content_style": "photo",
    "allow_hflip": true,
    "preload_to_gpu": false,
    "virtual_length_multiplier": 4
  },
  "checkpoint": {
    "save_dir": "../adacut"
  },
  "inference": {
    "num_steps": 1,
    "temperature_lambda": 0.0,
    "temperature_threshold": 1.0,
    "use_cfg": false,
    "cfg_scale": 1.0,
    "use_source_repulsion": false,
    "repulsion_strength": 0.0
  }
}
