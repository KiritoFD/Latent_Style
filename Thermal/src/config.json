{
  "model": {
    "latent_channels": 4,
    "base_channels": 128,
    "style_dim": 256,
    "time_dim": 256,
    "num_styles": 4,
    "num_encoder_blocks": 2,
    "num_decoder_blocks": 5
  },
  "loss": {
    "w_style": 3.0,
    "w_mse": 20.0,
    "w_pyramid": 1.0,
    "pyramid_weights": {"low": 4.0, "mid": 2.0, "high": 1.0},
    "vel_smooth_weight": 0.05,
    "w_layout": 0.0,
    "patch_size": 5, 
    "num_projections": 64,
    "max_samples": 4096,
    "use_multiscale_swd": true,
    "swd_scales": [1, 2, 5, 9],
    "swd_scale_weights": [1.0, 1.5, 2.0, 1.0],
    "edge_boost": 0.0,
    "style_weights": [1.0, 5.0, 1.0, 1.0],
    "use_velocity_reg": true,
    "vel_reg_weight": 0.01
  },
  "training": {
    "batch_size": 192,
    "accumulation_steps": 1,
    "learning_rate": 1e-4,
    "min_learning_rate": 1e-6,
    "weight_decay": 1e-4,
    "num_epochs": 400,
    "warmup_epochs": 20,
    "scheduler": "cosine",
    "grad_clip_norm": 1.0,
    "use_adaptive_loss_norm": true,
    
    "label_drop_prob": 0.1,
    
    "use_avg_style_for_uncond": true,
    "epsilon": 0.01,
    "epsilon_warmup_epochs": 10,
    "structure_warmup_epochs": 10,
    "ode_integration_steps": 1,
    
    "use_amp": true,
    "use_cagrad": false,
    "use_compile": true,
    "use_gradient_checkpointing": false,
    "use_elastic_deform": true,
    "elastic_alpha": 3.0,
    
    "save_interval": 5,
    "eval_interval": 25,
    "full_eval_interval": 50,
    
    "test_image_dir": "/mnt/c/Users/xy/style_data/test",
    "resume_checkpoint": ""
  },
  "data": {
    "data_root": "../../data/latents",
    "style_subdirs": ["monet", "photo", "vangogh", "cezanne"],
    "style_prompts": [
      "a Monet-style painting",
      "a photorealistic photograph",
      "a Van Gogh-style painting",
      "a Cezanne-style painting"
    ]
  },
  "checkpoint": {
    "save_dir": "../AdaGN-patch-1259"
  },
  "inference": {
    "num_steps": 15,
    "temperature_lambda": 0.3,
    "temperature_threshold": 0.5,
    "use_cfg": true,
    "cfg_scale": 4.0,
    "cfg_decay": true,
    "use_source_repulsion": true,
    "repulsion_strength": 1.0
  }
